      "id": "basetable_old_api",
      "label": "BaseTable Old Imperative API (Deprecated)",
      "file_type": "document",
      "source_file": "apps/dms-material/src/app/shared/components/base-table/MIGRATION-GUIDE.md",
      "source_location": "### Before (Old Pattern)",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "deprecated_patterns": [
        "initDataSource() method with RxJS Observable-based loadFn",
        "@ViewChild(BaseTableComponent) for initialization",
        "manual refresh() calls after signal/state changes",
        "manual sort handler that calls refreshTable()"
      ],
      "rationale": "Imperative pattern incompatible with SmartNgRX signals; data source disconnected from signals; required manual lifecycle management"
    },
