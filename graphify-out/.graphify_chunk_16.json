    {
      "id": "electron_builder_over_forge",
      "label": "electron-builder Selected Over electron-forge",
      "file_type": "document",
      "source_file": "apps/electron/PACKAGING.md",
      "source_location": "## 1. Selected Packaging Tool",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "electron-builder is a drop-in that reads existing dist/ output without restructuring; electron-forge requires migrating to its own build pipeline which conflicts with Nx targets; electron-builder is the dominant pattern in Nx+Electron monorepos; configured via single electron-builder.yml alongside project.json"
    },
    {
      "id": "electron_asar_bundle",
      "label": "Asar Bundle Architecture (Inside vs Outside)",
      "file_type": "document",
      "source_file": "apps/electron/PACKAGING.md",
      "source_location": "## 2. Asar Bundle Contents",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "inside_asar": [
        "apps/electron/dist/main.js",
        "apps/electron/dist/preload.js",
        "dist/apps/server/ (Fastify bundle)",
        "dist/apps/dms-material/browser/ (Angular app)"
      ],
      "outside_asar_in_resources": [
        "prisma/migrations/ - prisma migrate deploy reads SQL at runtime",
        "prisma/schema.prisma - required by migrate deploy",
        "Prisma query engine binary - native binary must not be in asar",
        "SQLite dms.db at app.getPath(userData) - created at runtime"
      ],
      "rationale": "Files inside the asar are read-only; the SQLite .db file is created fresh in userData on first launch via prisma migrate deploy and must never be inside the asar"
    },
    {
      "id": "electron_database_url_strategy",
      "label": "DATABASE_URL Strategy via Electron userData",
      "file_type": "document",
      "source_file": "apps/electron/PACKAGING.md",
      "source_location": "## 3. DATABASE_URL Strategy",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "platform_paths": {
        "linux": "~/.config/{app-name}",
        "macos": "~/Library/Application Support/{app-name}",
        "windows": "%APPDATA%\\{app-name}"
      },
      "implementation": "Set DATABASE_URL on process.env in Electron main process before startServer() forks Fastify; forked child inherits it automatically via spread of process.env",
      "rationale": "DATABASE_URL must be set before server fork so child inherits it; server's initializeDatabaseUrl() already reads process.env.DATABASE_URL as non-AWS fallback"
    },
    {
      "id": "electron_prisma_migration_packaged",
      "label": "Prisma Migration Strategy in Packaged App",
      "file_type": "document",
      "source_file": "apps/electron/PACKAGING.md",
      "source_location": "## 4. Prisma Migration Strategy",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "timing": "Migrations run in Electron main process before startServer() forks Fastify",
      "invocation": "execFileSync with bundled prisma binary from process.resourcesPath; no node_modules in packaged app",
      "sequence": [
        "findAvailablePort()",
        "set DATABASE_URL = userData/dms.db (Story 91.2)",
        "runMigrations() - prisma migrate deploy (Story 91.3)",
        "startServer(port)",
        "healthCheck(port)",
        "createWindow(port)"
      ],
      "rationale": "Running migrations before server fork guarantees schema is current before any API requests are served; first launch creates dms.db fresh via migrations without needing a seed DB copy"
    },
