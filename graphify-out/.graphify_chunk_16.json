      "id": "electronbuilder_extra_resources",
      "label": "electron-builder Extra Resources Config",
      "file_type": "document",
      "source_file": "apps/electron/electron-builder.yml",
      "source_location": "extraResources",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "resources": [
        "dist/apps/server -> apps/server",
        "dist/apps/dms-material/browser -> apps/dms-material/browser",
        "prisma/migrations -> prisma/migrations",
        "prisma/schema.prisma -> prisma/schema.prisma"
      ],
      "rationale": "All runtime files placed outside asar in resources/ so they are accessible via process.resourcesPath in main process and forked server; write-able and runtime-required files must not be inside the read-only asar"
    },
